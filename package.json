{
  "name": "letterpaths-workspace",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --filter editor dev",
    "dev:editor": "pnpm --filter editor dev",
    "dev:writing_app": "pnpm --filter writing_app dev",
    "build": "pnpm -r build",
    "build:pages": "pnpm -r build && node ./scripts/build-pages.mjs",
    "check:lib": "pnpm --filter letterpaths build",
    "test:kerning": "pnpm --filter letterpaths test:join-spacing",
    "deploy": "pnpm run build:pages && pnpm --filter editor exec gh-pages -d ../../dist-pages"
  }
}
