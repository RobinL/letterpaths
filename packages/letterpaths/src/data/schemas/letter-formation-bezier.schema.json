{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/letter-formation-bezier.schema.json",
  "title": "Letter formation (bezier)",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "glyph", "strokes"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "glyph": {
      "type": "object",
      "additionalProperties": false,
      "required": ["char", "case", "style"],
      "properties": {
        "char": { "type": "string", "minLength": 1, "maxLength": 2 },
        "case": { "type": "string", "enum": ["upper", "lower"] },
        "style": { "type": "string", "enum": ["print", "cursive"] },
        "name": { "type": "string" }
      }
    },
    "guides": {
      "type": "object",
      "description": "Optional guide positions for typography alignment and sidebearings.",
      "additionalProperties": false,
      "required": ["xHeight", "baseline"],
      "properties": {
        "ascender": { "type": "number" },
        "xHeight": { "type": "number" },
        "baseline": { "type": "number" },
        "descender": { "type": "number" },
        "leftSidebearing": { "type": "number" },
        "rightSidebearing": { "type": "number" }
      }
    },
    "strokes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stroke" }
    }
  },
  "$defs": {
    "point": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "cubic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["p0", "p1", "p2", "p3"],
      "properties": {
        "p0": { "$ref": "#/$defs/point" },
        "p1": { "$ref": "#/$defs/point" },
        "p2": { "$ref": "#/$defs/point" },
        "p3": { "$ref": "#/$defs/point" },
        "segment": {
          "type": "string",
          "enum": [
            "lead-in",
            "entry",
            "body",
            "exit",
            "lead-out",
            "ascender",
            "descender",
            "dot"
          ]
        },
        "cornerStart": { "type": "boolean" },
        "cornerEnd": { "type": "boolean" }
      }
    },
    "stroke": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "phase", "curves"],
      "properties": {
        "kind": { "type": "string", "enum": ["stroke", "mark"] },
        "phase": { "type": "string", "enum": ["main", "deferred"] },
        "segment": {
          "type": "string",
          "enum": [
            "lead-in",
            "entry",
            "body",
            "exit",
            "lead-out",
            "ascender",
            "descender",
            "dot"
          ]
        },
        "mark": {
          "type": "object",
          "additionalProperties": false,
          "required": ["x", "y"],
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "size": { "type": "number", "exclusiveMinimum": 0 }
          }
        },
        "curves": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/cubic" }
        }
      }
    }
  }
}
