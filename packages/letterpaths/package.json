{
  "name": "letterpaths",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "profile:worksheet": "node --import tsx ./scripts/profile-worksheet.ts",
    "typecheck": "tsc --noEmit",
    "test:formation-arrows": "pnpm run build && node --test test/formation-arrows.test.mjs",
    "test:join-spacing": "pnpm run build && node --test test/join-spacing.test.mjs"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  }
}
